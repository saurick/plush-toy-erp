{
  "contract": "workflow.task-mutation/v1",
  "vectors": [
    {
      "name": "canonical_base",
      "operation": "complete",
      "params": {
        "task_id": 42,
        "expected_version": 1,
        "action_key": "complete",
        "payload": {
          "feedback": "  已核对  ",
          "evidence_refs": [" proof-b ", "proof-a", "proof-a", "", "   "],
          "surface_key": "  mobile_role_tasks  ",
          "entry_path": "  /erp/mobile/tasks  "
        }
      },
      "expected_payload": {
        "feedback": "已核对",
        "evidence_refs": ["proof-a", "proof-b"]
      }
    },
    {
      "name": "context_copy",
      "operation": "complete",
      "params": {
        "task_id": 42,
        "expected_version": 999,
        "action_key": "complete",
        "payload": {
          "feedback": "已核对",
          "evidence_refs": ["proof-b", "proof-a"],
          "surface_key": "desktop_task_board",
          "entry_path": "/erp/task-board"
        }
      },
      "expected_payload": {
        "feedback": "已核对",
        "evidence_refs": ["proof-a", "proof-b"]
      }
    },
    {
      "name": "feedback_changed",
      "operation": "complete",
      "params": {
        "task_id": 42,
        "expected_version": 1,
        "action_key": "complete",
        "payload": {
          "feedback": "需要复核",
          "evidence_refs": ["proof-a", "proof-b"],
          "surface_key": "mobile_role_tasks"
        }
      },
      "expected_payload": {
        "feedback": "需要复核",
        "evidence_refs": ["proof-a", "proof-b"]
      }
    },
    {
      "name": "evidence_changed",
      "operation": "complete",
      "params": {
        "task_id": 42,
        "expected_version": 1,
        "action_key": "complete",
        "payload": {
          "feedback": "已核对",
          "evidence_refs": ["proof-a", "proof-c"],
          "surface_key": "mobile_role_tasks"
        }
      },
      "expected_payload": {
        "feedback": "已核对",
        "evidence_refs": ["proof-a", "proof-c"]
      }
    },
    {
      "name": "empty_optional_fields",
      "operation": "complete",
      "params": {
        "task_id": 42,
        "expected_version": 1,
        "action_key": "complete",
        "payload": {
          "feedback": "   ",
          "evidence_refs": ["", "   "],
          "surface_key": "   ",
          "entry_path": "   "
        }
      },
      "expected_payload": {}
    }
  ],
  "relations": [
    {
      "name": "surface context and version do not change intent",
      "left": "canonical_base",
      "right": "context_copy",
      "equal": true
    },
    {
      "name": "feedback changes intent",
      "left": "canonical_base",
      "right": "feedback_changed",
      "equal": false
    },
    {
      "name": "evidence changes intent",
      "left": "canonical_base",
      "right": "evidence_changed",
      "equal": false
    }
  ]
}
