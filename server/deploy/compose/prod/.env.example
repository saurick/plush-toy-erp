# 迁移到新服务器时，复制为 .env 并按实际环境调整

# 项目标识（用于容器名等）
PROJECT_SLUG=plush-toy-erp
ERP_CUSTOMER_KEY=demo

# 应用镜像
APP_IMAGE=plush-toy-erp-server:dev
WEB_IMAGE=plush-toy-erp-web:dev
POSTGRES_IMAGE=postgres:18.1
JAEGER_IMAGE=jaegertracing/all-in-one:1.76.0

# 时区
TZ=Asia/Shanghai
POSTGRES_MEM_LIMIT=256m
POSTGRES_MEM_RESERVATION=128m
JAEGER_MEM_LIMIT=96m
JAEGER_MEM_RESERVATION=48m
APP_MEM_LIMIT=896m
APP_MEM_RESERVATION=384m
WEB_MEM_LIMIT=96m
WEB_MEM_RESERVATION=48m
# 如果 POSTGRES_PASSWORD 包含 @、:、/、%、# 等 URL 特殊字符，POSTGRES_DSN 中的密码必须先 URL 编码。
POSTGRES_DSN=postgres://postgres:change-this-prod-postgres-password@postgres:5432/plush_erp?sslmode=disable
TRACE_ENDPOINT=jaeger:4318
TRACE_RATIO=0.1
WEB_API_ORIGIN=http://app-server:8300
WEB_PROXY_PREFIXES=/rpc,/templates
WEB_PROXY_TIMEOUT_MS=30000
ERP_PDF_CHROME_PATH=/usr/bin/chromium
ERP_PDF_RENDER_CONCURRENCY=2
ERP_PDF_WARMUP_ENABLED=true
APP_JWT_SECRET=change-this-prod-jwt-secret
APP_AUTH_SMS_MODE=disabled
# APP_AUTH_SMS_MODE=provider 时启用阿里云号码认证 PNVS 短信认证；不要把真实 AK 写入 Git。
# APP_AUTH_SMS_ALIYUN_ACCESS_KEY_ID=
# APP_AUTH_SMS_ALIYUN_ACCESS_KEY_SECRET=
# APP_AUTH_SMS_ALIYUN_SIGN_NAME=速通互联验证码
# APP_AUTH_SMS_ALIYUN_TEMPLATE_CODE=100001
# APP_AUTH_SMS_ALIYUN_TEMPLATE_PARAM={"code":"##code##","min":"5"}
# APP_AUTH_SMS_ALIYUN_SCHEME_NAME=
APP_ADMIN_USERNAME=admin
# 首次初始化新库 bootstrap 管理员时，临时设置 BOOTSTRAP_ADMIN_ONCE=true 并注入 APP_ADMIN_PASSWORD；
# 初始化成功后必须移除 APP_ADMIN_PASSWORD 并恢复为 false。
BOOTSTRAP_ADMIN_ONCE=false
ERP_DEBUG_ENV=prod
ERP_DEBUG_SEED_ENABLED=false
ERP_DEBUG_CLEANUP_ENABLED=false
ERP_DEBUG_CLEANUP_SCOPE=debug_run

# 对外端口
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5435
APP_HTTP_BIND_ADDR=127.0.0.1
APP_HTTP_PORT=8300
APP_GRPC_BIND_ADDR=127.0.0.1
APP_GRPC_PORT=9300
WEB_DESKTOP_PORT=5175

# Jaeger 端口默认只绑定宿主机 loopback；远程查看优先使用 SSH tunnel。
JAEGER_BIND_ADDR=127.0.0.1
JAEGER_5775_PORT=15775
JAEGER_6831_PORT=16831
JAEGER_6832_PORT=16832
JAEGER_5778_PORT=15778
JAEGER_UI_PORT=16687
JAEGER_14268_PORT=24268
JAEGER_14250_PORT=24250
JAEGER_9411_PORT=19411
JAEGER_OTLP_GRPC_PORT=14317
JAEGER_OTLP_HTTP_PORT=14318

# PostgreSQL 参数
POSTGRES_PASSWORD=change-this-prod-postgres-password
POSTGRES_DB=plush_erp
POSTGRES_USER=postgres

# 宿主机数据路径
POSTGRES_DATA_DIR=/data/plush-toy-erp/postgres
# 宿主机 migration 锁的私有目录；用自定义路径时需在调用 migrate_online.sh 前显式 export。
MIGRATION_LOCK_FILE=/run/lock/plush-toy-erp/atlas-migrate.lock

# Jaeger span metrics 查询 Prometheus 地址
PROMETHEUS_SERVER_URL=http://host.docker.internal:3004
