# 迁移到新服务器时，复制为 .env 并按实际环境调整

# 项目标识（用于容器名等）
PROJECT_SLUG=plush-toy-erp

# 应用镜像
APP_IMAGE=plush-toy-erp-server:dev

# 时区
TZ=Asia/Shanghai
POSTGRES_MEM_LIMIT=256m
POSTGRES_MEM_RESERVATION=128m
APP_MEM_LIMIT=160m
APP_MEM_RESERVATION=80m
POSTGRES_DSN=postgres://postgres:change-this-prod-postgres-password@postgres:5432/plush_toy_erp?sslmode=disable
TRACE_ENDPOINT=

# 对外端口
POSTGRES_PORT=5433
APP_HTTP_PORT=8200
APP_GRPC_PORT=9200

# PostgreSQL 参数
POSTGRES_PASSWORD=change-this-prod-postgres-password
POSTGRES_DB=plush_toy_erp
POSTGRES_USER=postgres

# 宿主机数据路径
POSTGRES_DATA_DIR=/data/plush-toy-erp/postgres
