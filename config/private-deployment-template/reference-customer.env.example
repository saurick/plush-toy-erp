# Engineering reference only. Copy to a controlled path and replace every placeholder.
PROJECT_SLUG=plush-toy-erp-reference-customer
COMPOSE_PROJECT_NAME=plush-toy-erp-reference-customer
ERP_CUSTOMER_KEY=reference-customer

APP_IMAGE=plush-toy-erp-server:<fixed-release-tag>
WEB_IMAGE=plush-toy-erp-web:<fixed-release-tag>
POSTGRES_IMAGE=postgres:18.1
JAEGER_IMAGE=jaegertracing/all-in-one:1.76.0
TZ=Asia/Shanghai

POSTGRES_DB=plush_erp_reference_customer
POSTGRES_USER=reference_customer
POSTGRES_PASSWORD=change-this-reference-customer-db-password
POSTGRES_DATA_DIR=/data/plush-toy-erp-reference-customer/postgres
POSTGRES_DSN=postgres://reference_customer:change-this-reference-customer-db-password@postgres:5432/plush_erp_reference_customer?sslmode=disable

# Optional Compose logging override values; these are consumed by
# reference-customer.override.example.yml and do not invent an application file store.
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILE=5
# migrate_online.sh does not source this file; export the same value before migration.
MIGRATION_LOCK_FILE=/run/lock/plush-toy-erp-reference-customer/atlas-migrate.lock

POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=55433
APP_HTTP_BIND_ADDR=127.0.0.1
APP_HTTP_PORT=8301
APP_GRPC_BIND_ADDR=127.0.0.1
APP_GRPC_PORT=9301
WEB_DESKTOP_PORT=5176
JAEGER_BIND_ADDR=127.0.0.1
JAEGER_UI_PORT=16687
JAEGER_OTLP_GRPC_PORT=14319
JAEGER_OTLP_HTTP_PORT=14320

TRACE_ENDPOINT=jaeger:4318
TRACE_RATIO=0.1
WEB_API_ORIGIN=http://app-server:8300
WEB_PROXY_PREFIXES=/rpc,/templates
WEB_PROXY_TIMEOUT_MS=30000
ERP_PDF_CHROME_PATH=/usr/bin/chromium
ERP_PDF_RENDER_CONCURRENCY=4
ERP_PDF_WARMUP=async

APP_JWT_SECRET=change-this-reference-customer-jwt-secret
APP_AUTH_SMS_MODE=disabled
APP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_ONCE=false
ERP_DEBUG_ENV=prod
ERP_DEBUG_SEED_ENABLED=false
ERP_DEBUG_CLEANUP_ENABLED=false
ERP_DEBUG_BUSINESS_CLEAR_ENABLED=false
ERP_DEBUG_CLEANUP_SCOPE=debug_run
